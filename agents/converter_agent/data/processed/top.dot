digraph top {
  rankdir=LR;
  node [shape=record fontname="Helvetica" fontsize=10];
  edge [fontname="Helvetica" fontsize=9];

  clk [shape=house label="clk\nin"];
  rst_n [shape=house label="rst_n\nin"];
  enable [shape=house label="enable\nin"];
  cfg_mode [shape=house label="cfg_mode\nin"];
  data_in [shape=house label="data_in\nin"];
  done [shape=invhouse label="done\nout"];
  result [shape=invhouse label="result\nout"];
  result_valid [shape=invhouse label="result_valid\nout"];

  u_ctrl [label="{ <clk> clk | <rst_n> rst_n | <enable> enable | <cfg_mode> cfg_mode } | u_ctrl\nctrl | { <start> start | <done> done | <mem_req> mem_req | <mem_addr> mem_addr }" fillcolor="blue" style="filled" shape="box"];
  u_datapath [label="{ <clk> clk | <rst_n> rst_n | <start> start | <data_in> data_in | <mem_data> mem_data | <mem_ack> mem_ack } | u_datapath\ndatapath | { <data_out> data_out | <valid> valid | <wr_en> wr_en }"];
  u_memory_intf [label="{ <clk> clk | <rst_n> rst_n | <mem_req> mem_req | <mem_addr> mem_addr } | u_memory_intf\nmemory_intf | { <mem_data> mem_data | <mem_ack> mem_ack }" fillcolor="orange" style="filled" shape="box"];
  u_fifo [label="{ <clk> clk | <rst_n> rst_n | <wr_en> wr_en | <din> din | <rd_en> rd_en } | u_fifo\nfifo | { <dout> dout | <full> full | <empty> empty }"];
  u_output_formatter [label="{ <clk> clk | <rst_n> rst_n | <raw_data> raw_data | <data_valid> data_valid | <empty> empty } | u_output_formatter\noutput_formatter | { <result> result | <result_valid> result_valid | <rd_en> rd_en }"];

  clk -> u_ctrl:clk [label="clk" style="dashed"];
  clk -> u_datapath:clk [label="clk" style="dashed"];
  clk -> u_memory_intf:clk [label="clk" style="dashed"];
  clk -> u_fifo:clk [label="clk" style="dashed"];
  clk -> u_output_formatter:clk [label="clk" style="dashed"];
  rst_n -> u_ctrl:rst_n [label="rst_n"];
  rst_n -> u_datapath:rst_n [label="rst_n"];
  rst_n -> u_memory_intf:rst_n [label="rst_n"];
  rst_n -> u_fifo:rst_n [label="rst_n"];
  rst_n -> u_output_formatter:rst_n [label="rst_n"];
  enable -> u_ctrl:enable [label="enable"];
  cfg_mode -> u_ctrl:cfg_mode [label="cfg_mode"];
  data_in -> u_datapath:data_in [label="data_in"];
  u_ctrl:start -> u_datapath:start [label="w_start"];
  u_ctrl:done -> done [label="done"];
  u_ctrl:mem_req -> u_memory_intf:mem_req [label="w_mem_req"];
  u_ctrl:mem_addr -> u_memory_intf:mem_addr [label="w_mem_addr"];
  u_datapath:mem_data -> u_memory_intf:mem_data [label="w_mem_data"];
  u_datapath:mem_ack -> u_memory_intf:mem_ack [label="w_mem_ack"];
  u_datapath:data_out -> u_fifo:din [label="w_dp_data_out"];
  u_datapath:valid -> u_output_formatter:data_valid [label="w_dp_valid"];
  u_datapath:wr_en -> u_fifo:wr_en [label="w_wr_en"];
  u_fifo:dout -> u_output_formatter:raw_data [label="w_fifo_dout"];
  u_fifo:full -> u_fifo:full [label="w_fifo_full"];
  u_fifo:empty -> u_output_formatter:empty [label="w_fifo_empty"];
  u_output_formatter:result -> result [label="result"];
  u_output_formatter:result_valid -> result_valid [label="result_valid"];
  u_output_formatter:rd_en -> u_fifo:rd_en [label="w_rd_en"];
}